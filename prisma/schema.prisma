generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  projects        Project[]
  subscriptions   Subscription[]
  usageLogs       UsageLog[]
  previews        Preview[]
  chatSessions    ChatSession[]
  chatMessages    ChatMessage[]
  projectMembers  ProjectMember[]
}

model Plan {
  id                 Int      @id @default(autoincrement())
  name               String   @unique
  stripePriceId      String   @unique
  maxProjects        Int
  maxTokenPerDay     Int
  maxPreviews        Int
  unlimitedAIUsage   Boolean  @default(false)
  active             Boolean  @default(true)

  subscriptions Subscription[]
}

model Subscription {
  id                     Int      @id @default(autoincrement())
  userId                 Int
  planId                 Int

  stripeSubscriptionId   String   @unique

  startDate              DateTime
  endDate                DateTime?

  status                 SubscriptionStatus

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan Plan @relation(fields: [planId], references: [id])

  @@index([userId])
  @@index([planId])
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
}

model Project {
  id          Int      @id @default(autoincrement())
  userId      Int

  name        String
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  files         ProjectFile[]
  previews      Preview[]
  usageLogs     UsageLog[]
  chatSessions  ChatSession[]
  chatMessages  ChatMessage[]
  members       ProjectMember[]

  @@index([userId])
}

model ProjectFile {
  id        Int      @id @default(autoincrement())
  projectId Int

  fileName  String
  filePath  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  previews Preview[]

  @@index([projectId])
}

model ProjectMember {
  id        Int      @id @default(autoincrement())
  projectId Int
  userId    Int

  role      ProjectMemberRole

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
}

enum ProjectMemberRole {
  OWNER
  EDITOR
  VIEWER
}

model UsageLog {
  id          Int      @id @default(autoincrement())

  userId      Int
  projectId   Int

  action      String

  tokenUsed   Int
  durationMs  Int

  metadata    Json?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
}

model Preview {
  id         Int      @id @default(autoincrement())

  userId     Int
  projectId  Int
  fileId      Int

  podUrl     String
  tokenUsed  Int

  status     PreviewStatus

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  file ProjectFile @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([projectId])
  @@index([fileId])
}

enum PreviewStatus {
  PENDING
  COMPLETED
  FAILED
}

model ChatSession {
  id         Int      @id @default(autoincrement())

  sessionId  String   @unique

  userId     Int
  projectId  Int

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  messages ChatMessage[]

  @@unique([userId, projectId])
  @@index([projectId])
}

model ChatMessage {
  id         Int      @id @default(autoincrement())

  sessionId  Int

  userId     Int
  projectId  Int

  message    String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
  @@index([projectId])
}

